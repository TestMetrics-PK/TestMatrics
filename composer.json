{
    "name": "testmatrics/testmatrics",
    "description": "TestMatrics Phase 1 scaffold",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "laravel/framework": "^12.0",
        "livewire/livewire": "^3.0"
    },
    "require-dev": {
        "laravel/breeze": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    }
}
